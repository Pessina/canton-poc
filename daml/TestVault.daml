module TestVault where

import DA.Optional (fromSome, isSome, isNone)
import DA.List (head)
import DA.Crypto.Text (byteCount)
import Daml.Script

import Erc20Vault
import TestFixtures

------------------------------------------------------------------------
-- Deposit lifecycle
------------------------------------------------------------------------

testDepositLifecycle : Script ()
testDepositLifecycle = do
  issuer    <- allocateParty "Issuer"
  depositor <- allocateParty "Depositor"
  mpc       <- allocateParty "Mpc"

  orchCid <- submit issuer do
    createCmd VaultOrchestrator with
      issuer; mpc; mpcPublicKey = testPubKeyHex; vaultAddress = sampleVaultAddress; vaultId = "test-vault"

  proposalCid <- submit (actAs depositor <> readAs issuer) do
    exerciseCmd orchCid RequestDepositAuth with
      requester = depositor

  authCid <- submit issuer do
    exerciseCmd orchCid ApproveDepositAuth with
      proposalCid
      remainingUses = 3

  let depositPath = partyToText depositor
  pendingCid <- submit (actAs depositor <> readAs issuer) do
    exerciseCmd orchCid RequestEvmDeposit with
      requester = depositor; path = depositPath; evmParams = sampleEvmParams
      authCidText = ""; keyVersion = 1; algo = "ECDSA"; dest = "ethereum"; authCid

  pending <- queryContractId depositor pendingCid
  let pd = fromSome pending
  assertMsg "requestId must be 32 bytes" (byteCount pd.requestId == 32)
  assertMsg "path must match" (pd.path == partyToText depositor <> "," <> depositPath)
  assertMsg "evmParams must match" (pd.evmParams == sampleEvmParams)

------------------------------------------------------------------------
-- RequestDepositAuth creates proposal
------------------------------------------------------------------------

testRequestDepositAuth : Script ()
testRequestDepositAuth = do
  issuer    <- allocateParty "Issuer"
  depositor <- allocateParty "Depositor"
  mpc       <- allocateParty "Mpc"

  orchCid <- submit issuer do
    createCmd VaultOrchestrator with
      issuer; mpc; mpcPublicKey = testPubKeyHex; vaultAddress = sampleVaultAddress; vaultId = "test-vault"

  proposalCid <- submit (actAs depositor <> readAs issuer) do
    exerciseCmd orchCid RequestDepositAuth with
      requester = depositor

  proposal <- queryContractId issuer proposalCid
  let p = fromSome proposal
  assertMsg "proposal issuer" (p.issuer == issuer)
  assertMsg "proposal owner" (p.owner == depositor)

------------------------------------------------------------------------
-- ApproveDepositAuth creates authorization
------------------------------------------------------------------------

testApproveDepositAuth : Script ()
testApproveDepositAuth = do
  issuer    <- allocateParty "Issuer"
  depositor <- allocateParty "Depositor"
  mpc       <- allocateParty "Mpc"

  orchCid <- submit issuer do
    createCmd VaultOrchestrator with
      issuer; mpc; mpcPublicKey = testPubKeyHex; vaultAddress = sampleVaultAddress; vaultId = "test-vault"

  proposalCid <- submit (actAs depositor <> readAs issuer) do
    exerciseCmd orchCid RequestDepositAuth with
      requester = depositor

  authCid <- submit issuer do
    exerciseCmd orchCid ApproveDepositAuth with
      proposalCid; remainingUses = 5

  auth <- queryContractId issuer authCid
  let a = fromSome auth
  assertMsg "auth issuer" (a.issuer == issuer)
  assertMsg "auth mpc" (a.mpc == mpc)
  assertMsg "auth owner" (a.owner == depositor)
  assertMsg "auth remainingUses" (a.remainingUses == 5)

------------------------------------------------------------------------
-- RequestEvmDeposit validates and decrements auth card
------------------------------------------------------------------------

testRequestEvmDepositBurnsAuthCard : Script ()
testRequestEvmDepositBurnsAuthCard = do
  issuer    <- allocateParty "Issuer"
  depositor <- allocateParty "Depositor"
  mpc       <- allocateParty "Mpc"

  orchCid <- submit issuer do
    createCmd VaultOrchestrator with
      issuer; mpc; mpcPublicKey = testPubKeyHex; vaultAddress = sampleVaultAddress; vaultId = "test-vault"

  proposalCid <- submit (actAs depositor <> readAs issuer) do
    exerciseCmd orchCid RequestDepositAuth with
      requester = depositor

  authCid <- submit issuer do
    exerciseCmd orchCid ApproveDepositAuth with
      proposalCid; remainingUses = 2

  let depositPath = partyToText depositor
  _pendingCid <- submit (actAs depositor <> readAs issuer) do
    exerciseCmd orchCid RequestEvmDeposit with
      requester = depositor; path = depositPath; evmParams = sampleEvmParams
      authCidText = ""; keyVersion = 1; algo = "ECDSA"; dest = "ethereum"; authCid

  oldAuth <- queryContractId issuer authCid
  assertMsg "original auth card must be archived" (oldAuth == None)

  auths <- queryFilter @DepositAuthorization issuer (\a -> a.owner == depositor)
  assertMsg "decremented auth card must exist" (length auths == 1)
  let (_, decremented) = head auths
  assertMsg "decremented remainingUses" (decremented.remainingUses == 1)

------------------------------------------------------------------------
-- ClaimEvmDeposit as requester
------------------------------------------------------------------------

testClaimAsRequester : Script ()
testClaimAsRequester = do
  issuer    <- allocateParty "Issuer"
  depositor <- allocateParty "Depositor"
  mpc       <- allocateParty "Mpc"

  orchCid <- submit issuer do
    createCmd VaultOrchestrator with
      issuer; mpc; mpcPublicKey = testPubKeyHex; vaultAddress = sampleVaultAddress; vaultId = "test-vault"

  proposalCid <- submit (actAs depositor <> readAs issuer) do
    exerciseCmd orchCid RequestDepositAuth with
      requester = depositor

  authCid <- submit issuer do
    exerciseCmd orchCid ApproveDepositAuth with
      proposalCid; remainingUses = 1

  let depositPath = partyToText depositor
  pendingCid <- submit (actAs depositor <> readAs issuer) do
    exerciseCmd orchCid RequestEvmDeposit with
      requester = depositor; path = depositPath; evmParams = sampleEvmParams
      authCidText = ""; keyVersion = 1; algo = "ECDSA"; dest = "ethereum"; authCid

  pending <- queryContractId depositor pendingCid
  let pd = fromSome pending

  ecdsaCid <- submit issuer do
    exerciseCmd orchCid SignEvmTx with
      requester = depositor; requestId = pd.requestId; r = "00"; s = "00"; v = 0

  outcomeCid <- submit issuer do
    exerciseCmd orchCid ProvideEvmOutcomeSig with
      requester = depositor; requestId = pd.requestId
      signature = testSignatureHex; mpcOutput = "01"

  submitMustFail (actAs depositor <> readAs issuer) do
    exerciseCmd orchCid ClaimEvmDeposit with
      requester = depositor; pendingCid; outcomeCid; ecdsaCid

  submitMustFail issuer do
    exerciseCmd orchCid ClaimEvmDeposit with
      requester = depositor; pendingCid; outcomeCid; ecdsaCid

  pure ()

------------------------------------------------------------------------
-- ClaimEvmDeposit rejects wrong requester
------------------------------------------------------------------------

testClaimRequesterMismatchFails : Script ()
testClaimRequesterMismatchFails = do
  issuer    <- allocateParty "Issuer"
  depositor <- allocateParty "Depositor"
  wrongUser <- allocateParty "WrongUser"
  mpc       <- allocateParty "Mpc"

  orchCid <- submit issuer do
    createCmd VaultOrchestrator with
      issuer; mpc; mpcPublicKey = testPubKeyHex; vaultAddress = sampleVaultAddress; vaultId = "test-vault"

  proposalCid <- submit (actAs depositor <> readAs issuer) do
    exerciseCmd orchCid RequestDepositAuth with
      requester = depositor

  authCid <- submit issuer do
    exerciseCmd orchCid ApproveDepositAuth with
      proposalCid; remainingUses = 1

  let depositPath = partyToText depositor
  pendingCid <- submit (actAs depositor <> readAs issuer) do
    exerciseCmd orchCid RequestEvmDeposit with
      requester = depositor; path = depositPath; evmParams = sampleEvmParams
      authCidText = ""; keyVersion = 1; algo = "ECDSA"; dest = "ethereum"; authCid

  pending <- queryContractId depositor pendingCid
  let pd = fromSome pending

  ecdsaCid <- submit issuer do
    exerciseCmd orchCid SignEvmTx with
      requester = depositor; requestId = pd.requestId; r = "00"; s = "00"; v = 0

  outcomeCid <- submit issuer do
    exerciseCmd orchCid ProvideEvmOutcomeSig with
      requester = depositor; requestId = pd.requestId
      signature = testSignatureHex; mpcOutput = "01"

  submitMustFail (actAs wrongUser <> readAs issuer) do
    exerciseCmd orchCid ClaimEvmDeposit with
      requester = wrongUser; pendingCid; outcomeCid; ecdsaCid

  pure ()

