------------------------------------------------------------------------
-- Happy-path ClaimEvmDeposit produces Erc20Holding
------------------------------------------------------------------------

testClaimHappyPath : Script ()
testClaimHappyPath = do
  issuer    <- allocateParty "Issuer"
  depositor <- allocateParty "Depositor"
  mpc       <- allocateParty "Mpc"

  orchCid <- submit issuer do
    createCmd VaultOrchestrator with
      issuer; mpc; mpcPublicKey = claimTestPubKey; vaultAddress = sampleVaultAddress; vaultId = "test-vault"

  dummyAuthCid <- submit issuer do
    createCmd DepositAuthorization with
      issuer; mpc; owner = depositor; remainingUses = 0

  pendingCid <- submit issuer do
    createCmd PendingEvmTx with
      issuer; requester = depositor; mpc
      requestId = claimTestRequestId; path = "test"; evmParams = sampleEvmParams; vaultId = "test-vault"
      nonceCidText = ""; source = DepositSource dummyAuthCid; keyVersion = 1; algo = "ECDSA"; dest = "ethereum"

  ecdsaCid <- submit issuer do
    createCmd EcdsaSignature with
      issuer; requester = depositor
      requestId = claimTestRequestId; r = "00"; s = "00"; v = 0

  outcomeCid <- submit issuer do
    createCmd EvmTxOutcomeSignature with
      issuer; requester = depositor; requestId = claimTestRequestId
      signature = claimTestSignature; mpcOutput = "01"

  holdingCid <- submit (actAs depositor <> readAs issuer) do
    exerciseCmd orchCid ClaimEvmDeposit with
      requester = depositor; pendingCid; outcomeCid; ecdsaCid

  holding <- queryContractId depositor holdingCid
  let h = fromSome holding
  assertMsg "holding owner" (h.owner == depositor)
  assertMsg "holding issuer" (h.issuer == issuer)
  assertMsg "holding erc20Address" (h.erc20Address == sampleEvmParams.to)
  assertMsg "holding amount" (h.amount == "0000000000000000000000000000000000000000000000000000000005f5e100")

  oldPending <- queryContractId depositor pendingCid
  assertMsg "pending archived" (oldPending == None)
  oldEcdsa <- queryContractId depositor ecdsaCid
  assertMsg "ecdsa archived" (oldEcdsa == None)
  oldOutcome <- queryContractId depositor outcomeCid
  assertMsg "outcome archived" (oldOutcome == None)

